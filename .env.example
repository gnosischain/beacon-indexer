# Storage Backend - choose either 'clickhouse' or 'parquet'
STORAGE_BACKEND=clickhouse

# Beacon Node
BEACON_NODE_URL=http://localhost:5052
# Optional API key for gated / archive beacon endpoints. Sent as a query parameter
# (name = BEACON_API_KEY_PARAM, default "apiKey"). Leave empty for no-auth nodes or
# nodes that carry credentials in the URL path itself (e.g. "https://host/<key>").
BEACON_API_KEY=
# BEACON_API_KEY_PARAM=apiKey

# ClickHouse Configuration (only used if STORAGE_BACKEND=clickhouse)
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=beacon_chain
CLICKHOUSE_SECURE=false

# Parquet Configuration (only used if STORAGE_BACKEND=parquet)
PARQUET_OUTPUT_DIR=./parquet_data
PARQUET_COMPRESSION=snappy
PARQUET_ROWS_PER_FILE=100000

# Loaders
# Comma-separated list of enabled loaders. Optional Electra+ state-queue loaders:
#   pending_consolidations, pending_deposits, pending_partial_withdrawals
# Enable them on networks that have activated Electra (safe to enable earlier —
# they fork-gate silently via ELECTRA_START_SLOT below).
ENABLED_LOADERS=blocks,validators,specs,genesis,rewards

# Validator Configuration
# Applies ONLY to the validators loader (daily or all_slots). The pending-queue
# loaders always run per-slot — same cadence as blocks/rewards.
VALIDATOR_MODE=daily

# Electra activation slot — gates the pending-queue loaders so historical
# backfills don't fire HTTP 400s on pre-Electra slots.
# Set to the network's Electra activation slot:
#   Gnosis mainnet: see specs / network docs
#   Ethereum mainnet: 11649024
# 0 disables gating (attempts the call on every slot).
ELECTRA_START_SLOT=0

# Backfill Configuration
START_SLOT=0
END_SLOT=
BACKFILL_WORKERS=4
CHUNK_SIZE=1000

# Logging
LOG_LEVEL=INFO

STORAGE_BACKEND=clickhouse
PARQUET_OUTPUT_DIR=./parquet_data
PARQUET_COMPRESSION=snappy
PARQUET_ROWS_PER_FILE=100000

REALTIME_SLOT_DELAY=100 